---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- HERO -->
  <section id="hero">
    <div class="hero-inner">
      <h1 class="hero-title">
        We build apps<br />
        <strong>worth using.</strong>
      </h1>
      <p class="hero-tagline">
        <em>Honest curiosity.</em> &nbsp;Good company. &nbsp;No destinations.
      </p>
      <p class="hero-desc">
        Prime Lattice LLC is a software development firm dedicated to crafting
        mobile experiences that are purposeful, precise, and built to last.
        We partner with founders and teams who care as much about the craft
        as the outcome.
      </p>
      <div class="hero-actions">
        <a href="#services" class="btn-primary">Our Services</a>
        <a href="#contact" class="btn-ghost">Start a Project</a>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services">
    <div class="services-header reveal">
      <div>
        <p class="section-label">What We Do</p>
        <h2 class="section-title">Mobile-first.<br /><strong>End-to-end.</strong></h2>
      </div>
    </div>
    <div class="services-grid reveal">
      <div class="service-card">
        <p class="service-num">01</p>
        <h3 class="service-name">iOS Development</h3>
        <p class="service-desc">Native Swift and SwiftUI applications built for performance, elegance, and App Store success. From architecture to launch.</p>
      </div>
      <div class="service-card">
        <p class="service-num">02</p>
        <h3 class="service-name">Android Development</h3>
        <p class="service-desc">Kotlin-first Android apps that feel at home on any device. We care about material design, accessibility, and speed.</p>
      </div>
      <div class="service-card">
        <p class="service-num">03</p>
        <h3 class="service-name">Cross-Platform Apps</h3>
        <p class="service-desc">React Native and Flutter solutions when you need reach without sacrificing quality. One codebase, two platforms, zero compromise.</p>
      </div>
      <div class="service-card">
        <p class="service-num">04</p>
        <h3 class="service-name">Product Strategy</h3>
        <p class="service-desc">We help teams define what to build and why. Discovery, scoping, and roadmapping before a single line of code is written.</p>
      </div>
      <div class="service-card">
        <p class="service-num">05</p>
        <h3 class="service-name">API & Backend</h3>
        <p class="service-desc">Scalable server infrastructure, REST and GraphQL APIs, and cloud integrations to power your mobile application.</p>
      </div>
      <div class="service-card">
        <p class="service-num">06</p>
        <h3 class="service-name">Maintenance & Growth</h3>
        <p class="service-desc">Long-term partnerships for ongoing updates, performance monitoring, and iterative feature development post-launch.</p>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section id="values">
    <div class="values-inner">
      <div class="reveal">
        <p class="section-label">Our Philosophy</p>
        <h2 class="section-title">Built on<br /><strong>honest work.</strong></h2>
        <div class="values-list">
          <div class="value-item">
            <div class="value-icon">✦</div>
            <div class="value-text">
              <h4>Curious by Default</h4>
              <p>We ask hard questions before writing code. Understanding the problem is the first deliverable.</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">◈</div>
            <div class="value-text">
              <h4>Transparent Partnership</h4>
              <p>No black boxes. You see the work, the reasoning, and the trade-offs at every step.</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">◇</div>
            <div class="value-text">
              <h4>Craft Over Speed</h4>
              <p>We'd rather take the time to do it right than ship something that becomes technical debt tomorrow.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="values-quote reveal">
        <blockquote>
          "Honest curiosity,<br />good company,<br /><em>no destinations.</em>"
        </blockquote>
        <cite>— Prime Lattice LLC</cite>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="process">
    <div class="process-header reveal">
      <p class="section-label">How We Work</p>
      <h2 class="section-title">A clear path<br /><strong>from idea to app store.</strong></h2>
    </div>
    <div class="process-steps reveal">
      <div class="process-step">
        <div class="step-num">01</div>
        <h4 class="step-title">Discovery</h4>
        <p class="step-desc">We learn your users, goals, and constraints. No assumptions — just good questions and careful listening.</p>
      </div>
      <div class="process-step">
        <div class="step-num">02</div>
        <h4 class="step-title">Design & Scope</h4>
        <p class="step-desc">Wireframes, technical architecture, and a clear roadmap. You know exactly what will be built before we begin.</p>
      </div>
      <div class="process-step">
        <div class="step-num">03</div>
        <h4 class="step-title">Build & Iterate</h4>
        <p class="step-desc">Agile sprints with regular demos. You stay close to the work and provide feedback at every milestone.</p>
      </div>
      <div class="process-step">
        <div class="step-num">04</div>
        <h4 class="step-title">Launch & Beyond</h4>
        <p class="step-desc">App store submission, monitoring, and ongoing support. The relationship doesn't end at go-live.</p>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="cta-text reveal">
      <p class="section-label">Get in Touch</p>
      <h2 class="section-title">Let's build<br /><strong>something real.</strong></h2>
      <p>Tell us about your project. We'll respond within one business day and always give you an honest assessment — even if we're not the right fit.</p>
    </div>
    <div class="cta-form reveal">
      <div id="form-success" style="display:none;padding:2rem;border:1px solid var(--gold);color:var(--gold);font-size:0.82rem;letter-spacing:0.1em;line-height:1.8;">
        ✦ &nbsp;Message received! We'll be in touch within one business day.
      </div>
	  <form id="contact-form" action="https://formspree.io/f/xzdkzzrj" method="POST" style="display:flex;flex-direction:column;gap:1rem;">
        <input type="text"  name="name"    placeholder="Your Name"     required />
        <input type="email" name="email"   placeholder="Email Address" required />
        <input type="text"  name="company" placeholder="Company / Project" />
        <textarea name="message" rows="4"  placeholder="Tell us about your project..." required></textarea>
        <input type="text"  name="_gotcha" style="display:none" />
        <button type="submit" class="btn-primary" id="submit-btn">Send Message</button>
      </form>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 4rem 4rem;
    z-index: 1;
  }
  .hero-inner { max-width: 900px; }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 1.05;
    color: var(--white);
    opacity: 0;
    animation: fadeUp 0.9s 0.4s forwards;
  }
  .hero-title strong { font-weight: 600; color: var(--gold-light); }
  .hero-tagline {
    margin-top: 2rem;
    font-size: 0.82rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0;
    animation: fadeUp 0.9s 0.6s forwards;
  }
  .hero-tagline em { font-style: normal; color: var(--gold); }
  .hero-desc {
    margin-top: 2.5rem;
    max-width: 520px;
    font-size: 0.88rem;
    line-height: 1.9;
    color: var(--muted);
    opacity: 0;
    animation: fadeUp 0.9s 0.8s forwards;
  }
  .hero-actions {
    margin-top: 3rem;
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.9s 1s forwards;
  }

  /* SERVICES */
  #services {
    padding: 8rem 4rem;
    border-top: 1px solid var(--border);
  }
  .services-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    gap: 2rem;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1px;
    background: var(--border);
  }
  .service-card {
    background: var(--navy-mid);
    padding: 2.5rem 2rem;
    transition: background 0.3s;
    position: relative;
    overflow: hidden;
  }
  .service-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .service-card:hover { background: var(--navy-light); }
  .service-card:hover::before { transform: scaleX(1); }
  .service-num {
    font-size: 0.62rem;
    letter-spacing: 0.25em;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }
  .service-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    color: var(--white);
    margin-bottom: 1rem;
  }
  .service-desc {
    font-size: 0.8rem;
    line-height: 1.85;
    color: var(--muted);
  }

  /* VALUES */
  #values {
    padding: 8rem 4rem;
    background: var(--navy-mid);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .values-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }
  .values-list {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
  }
  .value-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .value-icon {
    width: 32px;
    height: 32px;
    border: 1px solid var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--gold);
    font-size: 0.75rem;
  }
  .value-text h4 {
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: var(--white);
    margin-bottom: 0.4rem;
  }
  .value-text p {
    font-size: 0.78rem;
    line-height: 1.8;
    color: var(--muted);
  }
  .values-quote {
    border-left: 2px solid var(--gold);
    padding-left: 2.5rem;
  }
  .values-quote blockquote {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 300;
    line-height: 1.4;
    color: var(--white);
    margin-bottom: 2rem;
  }
  .values-quote blockquote em { font-style: italic; color: var(--gold-light); }
  .values-quote cite {
    font-size: 0.68rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    font-style: normal;
  }

  /* PROCESS */
  #process { padding: 8rem 4rem; border-top: 1px solid var(--border); }
  .process-header { margin-bottom: 4rem; }
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }
  .process-steps::before {
    content: '';
    position: absolute;
    top: 28px;
    left: 10%; right: 10%;
    height: 1px;
    background: var(--border);
  }
  .process-step { padding: 0 1.5rem 0 0; position: relative; }
  .step-num {
    width: 56px; height: 56px;
    border: 1px solid var(--gold);
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    color: var(--gold);
    margin-bottom: 1.8rem;
    position: relative;
    z-index: 1;
  }
  .step-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--white);
    margin-bottom: 0.75rem;
  }
  .step-desc { font-size: 0.78rem; line-height: 1.8; color: var(--muted); }

  /* CONTACT */
  #contact {
    padding: 6rem 4rem;
    background: var(--navy-mid);
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .cta-text p {
    margin-top: 1rem;
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.8;
    
  }
  .cta-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 300px;
	max-width: 480px;
  }
  .cta-form input,
  .cta-form textarea {
    background: var(--navy);
    border: 1px solid var(--border);
    color: var(--white);
    padding: 0.85rem 1.2rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    outline: none;
    transition: border-color 0.3s;
    resize: none;
  }
  .cta-form input::placeholder,
  .cta-form textarea::placeholder { color: var(--muted); }
  .cta-form input:focus,
  .cta-form textarea:focus { border-color: var(--gold); }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    #hero { padding: 7rem 2rem 3rem; }
    #services, #values, #process, #contact { padding: 5rem 2rem; }
    .values-inner { grid-template-columns: 1fr; gap: 3rem; }
    .process-steps { grid-template-columns: 1fr 1fr; gap: 3rem; }
    .process-steps::before { display: none; }
  }
  @media (max-width: 560px) {
    .process-steps { grid-template-columns: 1fr; }
    #contact { flex-direction: column; }
    .cta-form { min-width: unset; width: 100%; }
  }
</style>

<script>
  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));

  // Contact form
  const form = document.getElementById('contact-form');
  const successMsg = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn');
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'Sending...';
    submitBtn.style.opacity = '0.7';
    submitBtn.disabled = true;
    const data = new FormData(form);
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' }
      });
      if (res.ok) {
        form.style.display = 'none';
        successMsg.style.display = 'block';
      } else {
        submitBtn.textContent = 'Something went wrong — try again';
        submitBtn.style.opacity = '1';
        submitBtn.disabled = false;
      }
    } catch {
      submitBtn.textContent = 'Something went wrong — try again';
      submitBtn.style.opacity = '1';
      submitBtn.disabled = false;
    }
  });
</script>